{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "iTerminal",
  "version": "1.0.5",
  "identifier": "com.iterminal.ssh",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "iTerminal - SSH Manager",
        "width": 1400,
        "height": 900,

        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}